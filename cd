#include <stdio.h>
#include <ctype.h>
#include <string.h>

int main() {
    char str[100];
    int i = 0;

    printf("Enter code: ");
    scanf("%[^\n]", str);

    while (str[i] != '\0') {

        // Identifier or Keyword
        if (isalpha(str[i])) {
            char word[20];
            int j = 0;

            while (isalnum(str[i])) {
                word[j++] = str[i++];
            }

            word[j] = '\0';

            if (!strcmp(word, "int") || 
                !strcmp(word, "if") || 
                !strcmp(word, "return")) {
                printf("%s -> Keyword\n", word);
            } else {
                printf("%s -> Identifier\n", word);
            }
        }

        // Number
        else if (isdigit(str[i])) {
            printf("%c -> Constant\n", str[i]);
            i++;
        }

        // Operator
        else if (strchr("+-*/=", str[i])) {
            printf("%c -> Operator\n", str[i]);
            i++;
        }

        // Special Symbol
        else if (strchr("();{}", str[i])) {
            printf("%c -> Special Symbol\n", str[i]);
            i++;
        }

        else {
            i++;
        }
    }

    return 0;
}
