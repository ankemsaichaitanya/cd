#include <stdio.h>

int main() {
    int n, i, isFloat = 0;
    char var[20], type[20];   // store variables and types
    char expr[100];

    printf("Enter number of variables: ");
    scanf("%d", &n);

    // Input variables and their types
    for (i = 0; i < n; i++) {
        printf("Enter variable %d: ", i + 1);
        scanf(" %c", &var[i]);

        printf("Enter type of %c (i = int, f = float, c = char): ", var[i]);
        scanf(" %c", &type[i]);

        // If any variable is float → result becomes float
        if (type[i] == 'f')
            isFloat = 1;
    }

    printf("Enter expression (end with $): ");
    scanf(" %[^\n]", expr);

    // Check expression for division → makes result float
    for (i = 0; expr[i] != '\0'; i++) {
        if (expr[i] == '/') {
            isFloat = 1;
        }
    }

    // Check for char type → error
    for (i = 0; i < n; i++) {
        if (type[i] == 'c') {
            printf("Type Error: char not allowed in expression\n");
            return 0;
        }
    }

    // Final result type
    if (isFloat)
        printf("Result type: float\n");
    else
        printf("Result type: int\n");

    return 0;
}


